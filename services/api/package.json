{
  "name": "@picksleagues/api",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.tooling.json",
    "build": "echo '@picksleagues/api: no build step yet'",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run",
    "lint": "eslint . --max-warnings 0",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.2",
    "@hono/zod-openapi": "1.4.0",
    "@neondatabase/serverless": "^0.10.4",
    "drizzle-orm": "^0.43.1",
    "hono": "^4.12.19",
    "pg": "^8.20.0",
    "ws": "^8.18.2",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "@types/pg": "^8.20.0",
    "@types/ws": "^8.5.14",
    "dotenv": "^16.5.0",
    "drizzle-kit": "^0.31.1",
    "tsx": "^4.19.4",
    "vitest": "^4.1.6"
  }
}
