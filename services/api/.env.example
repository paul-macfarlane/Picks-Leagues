# Database connection string. Never commit the real value — .env is gitignored.
#
# Local development (default below): start Docker Postgres with
#   docker compose up -d
# and this connection string works as-is. See services/api/README.md.
#
# Neon (dev/preview/prod): replace with the pooled connection string from the
# Neon dashboard. The driver is chosen automatically from the host — no code
# change needed to switch.
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/picksleagues
