# Database connection string. Never commit the real value — .env is gitignored.
#
# Local development (default below): start Docker Postgres with
#   docker compose up -d
# and this connection string works as-is. See services/api/README.md.
#
# Neon (dev/preview/prod): replace with the pooled connection string from the
# Neon dashboard. The driver is chosen automatically from the host — no code
# change needed to switch.
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/picksleagues

# Shared secret for protecting /api/cron/* endpoints. Vercel Cron sends this
# in the Authorization: Bearer header automatically. Locally, any non-empty
# value works — generate a strong random string for production.
CRON_SECRET=replace-me-with-a-long-random-string

# Better Auth — JWT signing + cookie session secret. Generate with:
#   openssl rand -base64 32
# Must be at least 32 chars. Must be set in every environment.
BETTER_AUTH_SECRET=replace-me-with-openssl-rand-base64-32

# Better Auth — canonical app origin used for OAuth callback URLs and
# cookie domain. Local dev: http://localhost:3000 (Vite proxies to here).
# Preview/prod: the Vercel deploy URL.
BETTER_AUTH_URL=http://localhost:3000

# Google OAuth — create at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: $BETTER_AUTH_URL/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Discord OAuth — create at https://discord.com/developers/applications
# Redirect URI: $BETTER_AUTH_URL/api/auth/callback/discord
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
