    "@tanstack/react-query-devtools": "^5.100.14",
    "@tanstack/react-router": "^1.170.9",
    "@tanstack/react-router-devtools": "^1.167.0",
    "better-auth": "^1.6.11",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.17.0",
    "openapi-fetch": "0.17.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-hook-form": "^7.76.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
