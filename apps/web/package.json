    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.7",
    "jsdom": "^29.1.1",
    "openapi-typescript": "7.13.0",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  }
