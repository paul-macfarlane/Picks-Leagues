{
  "name": "@picksleagues/web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "build": "pnpm run gen:api && tsc --noEmit -p tsconfig.json && vite build",
    "gen:api": "pnpm --filter @picksleagues/api gen:api",
    "dev": "pnpm run gen:api && vite",
    "test": "echo '@picksleagues/web: no tests yet'",
    "lint": "eslint . --max-warnings 0"
  },
  "dependencies": {
    "@tanstack/react-router": "^1.170.4",
    "@tanstack/react-router-devtools": "^1.167.0",
    "openapi-fetch": "0.17.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@tanstack/router-plugin": "^1.168.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "openapi-typescript": "7.13.0",
    "vite": "^8.0.13"
  }
}
