{
  "name": "@picksleagues/web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "build": "pnpm run gen:api && tsc --noEmit -p tsconfig.json && vite build",
    "gen:api": "pnpm --filter @picksleagues/api gen:api",
    "dev": "pnpm run gen:api && vite",
    "test": "vitest run",
    "lint": "eslint . --max-warnings 0"
  },
